{
  "applicationId": "com.verbali.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "modes": {
    "window": {
      "title": "Verbali",
      "width": 1280,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": false
    }
  },
  "cli": {
    "binaryName": "Verbali",
    "resourcesPath": "dist/",
    "binaryVersion": "5.6.0",
    "clientVersion": "3.15.2",
    "copyResources": [
      "dist/*"
    ]
  },
  "build": {
    "electron": []
  },
  "nativeAllowList": [
    "os.*",
    "filesystem.*"
  ]
}